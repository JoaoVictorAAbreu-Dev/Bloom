# Bloom Android release configuration
# Do not put real values in this file.

AI_BACKEND_BASE_URL=https://your-bloom-ai-proxy.example.com
AI_BACKEND_CLIENT_TOKEN=replace_with_random_client_token

# Optional release signing. Required for installable production artifacts.
# Create a keystore locally, base64-encode it, and store these values as CI secrets.
BLOOM_RELEASE_KEYSTORE_BASE64=base64_encoded_jks_or_keystore
BLOOM_RELEASE_KEYSTORE_PASSWORD=replace_with_store_password
BLOOM_RELEASE_KEY_ALIAS=bloom-release
BLOOM_RELEASE_KEY_PASSWORD=replace_with_key_password

# Debug-only direct Groq fallback. Never use this for production release builds.
GROQ_API_KEY=your_debug_only_groq_key
GROQ_MODEL=groq/compound-mini
GROQ_BASE_URL=https://api.groq.com/openai/v1
